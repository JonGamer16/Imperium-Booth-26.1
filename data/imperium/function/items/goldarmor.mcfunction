clear @a[scores={rGoldArmor=1,onKill=1..}] golden_helmet[enchantments={"protection":3}]
clear @a[scores={rGoldArmor=1,onKill=1..}] golden_chestplate[enchantments={"protection":3}]
clear @a[scores={rGoldArmor=1,onKill=1..}] golden_leggings[enchantments={"protection":3}]
