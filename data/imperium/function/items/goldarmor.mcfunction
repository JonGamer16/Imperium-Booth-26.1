give @a[scores={rGoldArmor=1,onKill=1..}] golden_boots[enchantments={"protection":3,"imperium:chinks_curse":1,"imperium:brittle_curse":1},max_damage=80] 1
give @a[scores={rGoldArmor=1,onKill=1..}] golden_sword[enchantments={"sharpness":3,"sweeping_edge":3,"imperium:chinks_curse":1},max_damage=20] 1